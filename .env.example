# ─── Discord ────────────────────────────────────────────────────────────────────
# Bot token from https://discord.com/developers/applications → Bot → Token
DISCORD_TOKEN=your_bot_token_here

# Application ID from https://discord.com/developers/applications → General Information
CLIENT_ID=your_application_id_here

# ─── Discord Channel IDs ─────────────────────────────────────────────────────────
# Right-click a channel in Discord (Developer Mode must be ON) and select "Copy ID"
LP_CHANNEL_ID=channel_id_for_lp_updates
MOD_LOG_CHANNEL_ID=channel_id_for_moderation_logs
WELCOME_CHANNEL_ID=channel_id_for_welcome_and_farewell_messages

# ─── Auto-Role (optional) ────────────────────────────────────────────────────────
# Role ID to assign automatically when a new member joins. Leave blank to disable.
# AUTO_ROLE_ID=role_id_here

# ─── Riot Games ──────────────────────────────────────────────────────────────────
# API key from https://developer.riotgames.com (dev keys expire every 24h)
RIOT_API_KEY=RGAPI-your-key-here

# Server region — valid values: euw1 | na1 | kr | br1 | la1 | la2 | oc1 | ru | tr1 | jp1
REGION=euw1

# ─── Bot Settings ────────────────────────────────────────────────────────────────
# How often (in minutes) the LP tracker polls Riot API for changes
POLL_INTERVAL_MINUTES=5

# Set to "production" when deploying; "development" enables extra logging
NODE_ENV=development

# ─── XP System (optional tuning) ─────────────────────────────────────────────────
# XP awarded per message (default: 15)
# XP_PER_MESSAGE=15
# Cooldown between XP awards in seconds (default: 60)
# XP_COOLDOWN_SECONDS=60
# XP required per level (default: 100)
# XP_PER_LEVEL=100
# XP awarded for a correct trivia answer (default: 25)
# XP_TRIVIA_REWARD=25

# ─── Music Player ────────────────────────────────────────────────────────────────
# Optional: Spotify API credentials for better playlist/album support.
# Without these, Spotify URLs still work via YouTube search fallback.
# Get credentials at https://developer.spotify.com/dashboard → Create App
# SPOTIFY_CLIENT_ID=your_spotify_client_id
# SPOTIFY_CLIENT_SECRET=your_spotify_client_secret

# ─── Express REST API ─────────────────────────────────────────────────────────────
# Port the Express server listens on (default: 4000)
API_PORT=4000

# Secret key required in the "x-api-key" header for protected endpoints.
# If left blank, all API requests will be rejected (fail-closed).
API_SECRET_KEY=your_secret_api_key_here
